{
  "name": "mariadb-source-cdc-connector",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",

    "database.hostname": "a1961fab471c6487aa7b3f049f61cdf7-770154099.ap-northeast-2.elb.amazonaws.com",
    "database.port": "3306",
    "database.user": "skala",
    "database.password": "Skala25a!23$",
    "database.connectionTimeZone": "Asia/Seoul",
    "connect.timeout.ms": "30000",

    "database.server.id": "184054",
    "topic.prefix": "mariadb",

    "database.include.list": "cloud",
    "table.include.list": "cloud.users",
    "include.schema.changes": "false",

    "snapshot.mode": "initial",
    "snapshot.locking.mode": "minimal",

    "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
    "schema.history.internal.kafka.topic": "mariadb-schema-changes",
    "schema.history.internal.store.only.captured.tables.ddl": "true",
    "schema.history.internal.skip.unparseable.ddl": "true",

    "topic.creation.default.partitions": "3",
    "topic.creation.default.replication.factor": "1",

    "max.batch.size": "2048",
    "max.queue.size": "8192",
    "poll.interval.ms": "1000",

    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true",

    "transforms": "unwrap",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.add.fields": "op,ts_ms,db,table",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "none"
  }
}

