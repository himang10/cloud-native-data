# ============================================
# Outbox Producer 환경 변수 설정 예제
# ============================================

# Spring 프로파일 (local, prod, dev 등)
SPRING_PROFILES_ACTIVE=local

# 데이터베이스 설정
DB_URL=jdbc:mariadb://localhost:3306/cloud?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Seoul
DB_USERNAME=root
DB_PASSWORD=your_password_here

# HikariCP 커넥션 풀 설정
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

# 서버 설정
SERVER_PORT=8080

# 로깅 설정
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# JPA 설정
SHOW_SQL=true
FORMAT_SQL=true

# 헬스체크 설정
HEALTH_SHOW_DETAILS=when-authorized

# 로그 파일 경로 (프로덕션)
# LOG_FILE_PATH=/var/log/outbox-producer/application.log

# ============================================
# 사용 방법
# ============================================
# 1. 이 파일을 복사하여 .env 파일로 이름 변경
# 2. 실제 값으로 수정
# 3. 로컬 실행: java -jar -Dspring.profiles.active=local app.jar
# 4. 도커 실행: docker-compose up 또는 환경 변수 설정
# 5. Kubernetes: ConfigMap/Secret으로 환경 변수 주입
# ============================================

# ============================================
# 프로덕션 환경 주의사항
# ============================================
# - DB_PASSWORD는 반드시 보안이 강화된 값으로 설정
# - LOG_LEVEL은 INFO 이상으로 설정
# - SHOW_SQL은 false로 설정
# - HEALTH_SHOW_DETAILS는 never로 설정
# - 모든 민감한 정보는 Kubernetes Secret으로 관리
# ============================================
